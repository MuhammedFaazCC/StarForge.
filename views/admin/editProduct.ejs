<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Edit Product - StarForge</title>

  <link rel="stylesheet" href="/css/admin/common.css" />
  <link rel="stylesheet" href="/css/admin/addProduct.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body>
  <%- include('../partials/admin/navbar') %>

  <div class="main-content">
    <div class="container">
      <h2>Edit Product</h2>

      <form
        id="editProductForm"
        action="/admin/products/edit/<%= product._id %>"
        method="POST"
        enctype="multipart/form-data"
      >

        <!-- PRODUCT DETAILS -->
        <div class="form-section">
          <h3>Product Details</h3>

          <div class="form-group">
            <label>Product Name</label>
            <input id="name" name="name" value="<%= product.name %>" />
          </div>

          <div class="form-group">
            <label>Brand</label>
            <input id="brand" name="brand" value="<%= product.brand %>" />
          </div>

          <div class="form-group">
            <label>Price</label>
            <input id="price" name="price" value="<%= product.price %>" />
          </div>

          <div class="form-group">
            <label>Offer (%)</label>
            <input id="offer" name="offer" value="<%= product.offer %>" />
          </div>

          <div class="form-group">
            <label>Description</label>
            <textarea id="description" name="description"><%= product.description %></textarea>
          </div>

          <div class="form-group">
            <label>Category</label>
            <select id="category" name="category">
              <% categories.forEach(c => { %>
                <option value="<%= c._id %>" <%= c._id.toString() === product.category.toString() ? 'selected' : '' %>>
                  <%= c.name %>
                </option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label>Size</label>
            <input id="sizes" name="sizes" value="<%= product.sizes.join(', ') %>" />
          </div>

          <div class="form-group">
            <label>Rim Material</label>
            <input id="rimMaterial" name="rimMaterial" value="<%= product.rimMaterial %>" />
          </div>

          <div class="form-group">
            <label>Stock</label>
            <input id="stock" name="stock" value="<%= product.stock %>" />
          </div>
        </div>

        <!-- IMAGES -->
        <div class="form-section">
          <h3>Images</h3>

          <div class="form-group">
            <label>Main Image (optional)</label>
            <input type="file" id="mainImage" name="mainImage" accept="image/*" />
            <% if (product.mainImage) { %>
              <img src="<%= product.mainImage %>" width="100" />
              <label>
                <input type="checkbox" name="removeMainImage" /> Remove current
              </label>
            <% } %>
            <div id="mainImagePreview"></div>
          </div>

          <div class="form-group">
            <label>Additional Images</label>
            <input type="file" id="additionalImages" name="additionalImages" multiple />
            <div id="additionalImagesPreview"></div>

            <% product.additionalImages.forEach(img => { %>
              <div>
                <img src="<%= img %>" width="80" />
                <label>
                  <input type="checkbox" name="removedAdditional" value="<%= img %>" />
                  Remove
                </label>
              </div>
            <% }) %>
          </div>
        </div>

        <button type="submit">Update Product</button>
      </form>
    </div>
  </div>

  <!-- CROP MODAL -->
  <div id="cropModal" class="crop-modal">
    <div class="crop-modal-content">
      <h3>Crop Image</h3>
      <div class="crop-image-wrapper">
        <img id="cropImage" />
      </div>
      <div class="crop-buttons">
        <button id="cropButton" type="button">Crop</button>
        <button id="cancelCropButton" type="button">Cancel</button>
      </div>
    </div>
  </div>

  <script>
    window.__SERVER_MESSAGE__ = <%- JSON.stringify(message || null) %>;
  </script>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.12/cropper.min.js"></script>
  <script src="/js/admin/editProduct.js"></script>

  <%- include('../partials/admin/footer') %>
</body>
</html>
